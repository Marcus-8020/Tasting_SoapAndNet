<Project Sdk="Microsoft.NET.Sdk">

  <PropertyGroup>
    <OutputType>Exe</OutputType>
    <TargetFramework>net10.0</TargetFramework>
    <Nullable>enable</Nullable>
    <ImplicitUsings>enable</ImplicitUsings>
    <RootNamespace>PCKasseDbTest</RootNamespace>
  </PropertyGroup>

  <ItemGroup>
    <!--
      Microsoft.Data.SqlClient er den offisielle, moderne SQL Server-driveren for .NET.
      Dette er pakken du vil bruke i alle .NET-prosjekter mot SQL Server.
      (Den eldre System.Data.SqlClient er utdatert – bruk alltid denne.)
    -->
    <PackageReference Include="Microsoft.Data.SqlClient" Version="6.*" />
  </ItemGroup>

</Project>
